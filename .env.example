# ── Groq API (FREE — required for LearnBot chatbot) ──────────────────────────
# 1. Sign up free at: https://console.groq.com
# 2. Go to API Keys → Create API Key
# 3. Paste it below (must start with VITE_ so Vite exposes it to the browser)
VITE_GROQ_API_KEY=gsk_your_api_key_here

# ── Aiven PostgreSQL (optional — app works without this) ─────────────────────
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"


